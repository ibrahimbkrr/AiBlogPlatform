@model List<ResultArticleDto>
@{
    ViewData["Title"] = "ArticleList";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<main class="page-content">
    <!--breadcrumb-->
    <div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
        <div class="breadcrumb-title pe-3">Makaleler</div>
        <div class="ps-3">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0 p-0">
                    <li class="breadcrumb-item">
                        <a href="javascript:;"><i class="bx bx-home-alt"></i></a>
                    </li>
                    <li class="breadcrumb-item active" aria-current="page">Makale Listesi</li>
                </ol>
            </nav>
        </div>

    </div>
    <!--end breadcrumb-->

    <div class="card">
        <div class="card-body">
            <div class="d-flex align-items-center">
                <h5 class="mb-0">Makale Detayları</h5>
                <form class="ms-auto position-relative">
                    <div class="position-absolute top-50 translate-middle-y search-icon px-3"><i class="bi bi-search"></i></div>
                    <input class="form-control ps-5" type="text" placeholder="search">
                </form>
            </div>
            <div class="table-responsive mt-3">
                <table class="table align-middle">
                    <thead class="table-secondary">
                        <tr>
                            <th>#</th>
                            <th>Makale Başlığı</th>
                            <th>Makale Oluşturulma Tarihi</th>
                            <th>Makale Kategori Adı</th>
                            <th>Makale Yazarı</th>
                            <th>Makaleyi Sil</th>
                            <th>Makaleyi Güncelle</th>
                            <th>Makaleyi Sitede Gör</th>
                            

                            

                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.ArticleId</td>
                                <td>@item.ArticleTitle</td>
                                <td>@item.CreatedDate.ToString("dd-MMM-yyyy")</td>
								<td>@item.CategoryName</td>
                                <td>@item.AuthorName @item.AuthorSurname</td>
                                <td><a href="/AdminArticle/DeleteArticle/@item.ArticleId" class="btn btn-danger" data-bs-toggle="tooltip" data-bs-placement="bottom" title="Sil"><i class="bi bi-trash-fill"></i></a></td>
                                <td><a href="/AdminArticle/UpdateArticle/@item.ArticleId" class="btn btn-success" data-bs-toggle="tooltip" data-bs-placement="bottom" title="Güncelle"><i class="bi bi-pencil-fill"></i></a></td>
                                <td><a href="/Article/ArticleDetails/@item.ArticleId" class="btn btn-warning" data-bs-toggle="tooltip" data-bs-placement="bottom" title="Makale Detayları"><i class="bi bi-eye-fill"></i></a></td>


                             
                            </tr>

                        }


                    </tbody>
                </table>
                <a href="/AdminArticle/CreateArticle" class="btn btn-primary px-5">Yeni Makale Ekle</a>
            </div>
        </div>
    </div>





</main>

