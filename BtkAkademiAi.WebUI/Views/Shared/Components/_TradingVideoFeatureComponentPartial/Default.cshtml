<div class="back-trading-video">
    <div class="container">
        <div class="back-title">
            <h2>Video Oynatma</h2>
        </div>
        <div class="row">
            
            

            <div class="col-lg-8">
                <ul>
                    <li>
                        <div class="image-area">
                            <a href="#"><img src="@ViewBag.TradingFeatureImageUrl" alt="image"></a>
                            <a href="@ViewBag.TradingFeatureVideoUrl" class="popup-videos back-video"><i class="fa-solid fa-play"></i></a>
                            <div class="back-btm-content">
                                <h3><a href="#">@ViewBag.TradingFeatureTitle</a></h3>
                                <ul>
                                    <li class="back-author"><span><img src="@ViewBag.TradingFeatureAuthorImageUrl" alt="image"></span><a href="#">by @ViewBag.TradingFeatureAuthorName @ViewBag.TradingFeatureAuthorSurname</a></li>
                                    <li class="back-date"><span><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-clock"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg></span>@ViewBag.TradingFeatureCreatedDate</li>
                                </ul>
                            </div>
                        </div>
                    </li>
                </ul>
            </div>
            @await Component.InvokeAsync("_TradingVideoListComponentPartial")
        </div>
    </div>
</div>