@model List<ResultCommentDto>
@{
    ViewData["Title"] = "CommentList";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<main class="page-content">
    <!--breadcrumb-->
    <div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
        <div class="breadcrumb-title pe-3">Kategoriler</div>
        <div class="ps-3">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0 p-0">
                    <li class="breadcrumb-item">
                        <a href="javascript:;"><i class="bx bx-home-alt"></i></a>
                    </li>
                    <li class="breadcrumb-item active" aria-current="page">Kategori Listesi</li>
                </ol>
            </nav>
        </div>

    </div>
    <!--end breadcrumb-->

    <div class="card">
        <div class="card-body">
            <div class="d-flex align-items-center">
                <h5 class="mb-0">Yorum Detayları</h5>
                
            </div>
            <div class="table-responsive mt-3">
                <table class="table align-middle">
                    <thead class="table-secondary">
                        <tr>
                            <th>#</th>
                            <th>Yorum Metni</th>
                            <th>Yorum Tarihi</th>
                            <th>Yorum Yapanın Adı Soyadı</th>
                            <th>Yorum Yapılan İçerik</th>


                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.CommentId</td>
                                <td>@item.CommentText</td>
                                <td>@item.CommentDate</td>
								<td>@item.AuthorName @item.AuthorSurname</td>
								<td>@item.ArticleName</td>
                            </tr>

                        }


                    </tbody>
                </table>
                <a href="/Comment/CreateComment" class="btn btn-primary px-5">Yeni Yorum Ekle</a>
            </div>
        </div>
    </div>





</main>

