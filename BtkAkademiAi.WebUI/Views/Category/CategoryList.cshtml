@model List<ResultCategoryDto>

@{
    ViewData["Title"] = "Kategori Listesi";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<style>
    .category-card {
        border: none;
        border-radius: 16px;
        box-shadow: 0 8px 24px rgba(15, 23, 42, 0.08);
        overflow: hidden;
    }

    .category-card-header {
        background: linear-gradient(135deg, #f8fafc, #eef2ff);
        border-bottom: 1px solid #e5e7eb;
        padding: 22px 24px;
    }

    .category-title {
        font-size: 20px;
        font-weight: 700;
        color: #1f2937;
        margin-bottom: 4px;
    }

    .category-subtitle {
        color: #6b7280;
        font-size: 14px;
        margin-bottom: 0;
    }

    .category-table {
        margin-bottom: 0;
    }

    .category-table thead th {
        background-color: #f3f4f6;
        color: #374151;
        font-weight: 700;
        font-size: 14px;
        border-bottom: none;
        padding: 14px 16px;
        white-space: nowrap;
    }

    .category-table tbody td {
        padding: 15px 16px;
        vertical-align: middle;
        color: #111827;
        border-color: #eef0f3;
    }

    .category-table tbody tr {
        transition: all 0.2s ease;
    }

    .category-table tbody tr:hover {
        background-color: #f9fafb;
    }

    .category-id-badge {
        width: 38px;
        height: 32px;
        border-radius: 10px;
        background-color: #eef2ff;
        color: #3b5bfd;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
    }

    .category-name-box {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .category-icon {
        width: 38px;
        height: 38px;
        border-radius: 12px;
        background-color: #f1f5f9;
        color: #3b5bfd;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
    }

    .action-btn {
        min-width: 115px;
        border-radius: 10px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
    }

    .add-category-btn {
        border-radius: 12px;
        padding: 11px 22px;
        font-weight: 600;
        box-shadow: 0 8px 18px rgba(59, 91, 253, 0.25);
    }

    .empty-message {
        padding: 35px;
        text-align: center;
        color: #6b7280;
    }
</style>

<main class="page-content">

    <div class="page-breadcrumb d-none d-sm-flex align-items-center mb-4">
        <div class="breadcrumb-title pe-3 fw-semibold">Kategoriler</div>

        <div class="ps-3">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0 p-0">
                    <li class="breadcrumb-item">
                        <a href="javascript:;">
                            <i class="bx bx-home-alt"></i>
                        </a>
                    </li>
                    <li class="breadcrumb-item active" aria-current="page">
                        Kategori Listesi
                    </li>
                </ol>
            </nav>
        </div>
    </div>

    <div class="card category-card">

        <div class="category-card-header">
            <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">

                <div>
                    <h5 class="category-title">
                        Kategori Yönetimi
                    </h5>
                    <p class="category-subtitle">
                        Sistemde kayıtlı kategorileri görüntüleyebilir, güncelleyebilir, silebilir veya kategoriye ait makaleleri inceleyebilirsin.
                    </p>
                </div>

                <a href="/Category/CreateCategory" class="btn btn-primary add-category-btn">
                    <i class="bi bi-plus-circle me-1"></i>
                    Yeni Kategori Ekle
                </a>

            </div>
        </div>

        <div class="card-body p-4">

            <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-3">
                <span class="badge bg-primary px-3 py-2">
                    Toplam Kategori: @(Model != null ? Model.Count : 0)
                </span>
            </div>

            <div class="table-responsive">
                <table class="table table-hover align-middle category-table">

                    <thead>
                        <tr>
                            <th style="width: 90px;">ID</th>
                            <th>Kategori Adı</th>
                            <th class="text-center" style="width: 150px;">Makaleler</th>
                            <th class="text-center" style="width: 150px;">Güncelle</th>
                            <th class="text-center" style="width: 150px;">Sil</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <span class="category-id-badge">
                                            @item.CategoryId
                                        </span>
                                    </td>

                                    <td>
                                        <div class="category-name-box">
                                            <span class="category-icon">
                                                <i class="bi bi-folder2-open"></i>
                                            </span>

                                            <div>
                                                <div class="fw-semibold">
                                                    @item.CategoryName
                                                </div>
                                                <small class="text-muted">
                                                    Kategori kaydı
                                                </small>
                                            </div>
                                        </div>
                                    </td>

                                    <td class="text-center">
                                        <a href="/Category/CategoryDetails/@item.CategoryId"
                                           class="btn btn-outline-primary btn-sm action-btn"
                                           title="Kategoriye ait makaleler">
                                            <i class="bi bi-file-earmark-text"></i>
                                            Makaleler
                                        </a>
                                    </td>

                                    <td class="text-center">
                                        <a href="/Category/UpdateCategory/@item.CategoryId"
                                           class="btn btn-outline-warning btn-sm action-btn"
                                           title="Kategoriyi güncelle">
                                            <i class="bi bi-pencil-square"></i>
                                            Güncelle
                                        </a>
                                    </td>

                                    <td class="text-center">
                                        <a href="/Category/DeleteCategory/@item.CategoryId"
                                           class="btn btn-outline-danger btn-sm action-btn"
                                           title="Kategoriyi sil"
                                           onclick="return confirm('Bu kategoriyi silmek istediğinize emin misiniz?');">
                                            <i class="bi bi-trash3"></i>
                                            Sil
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5">
                                    <div class="empty-message">
                                        <i class="bi bi-folder-x fs-2 d-block mb-2"></i>
                                        Henüz kayıtlı kategori bulunmuyor.
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>
            </div>

        </div>
    </div>
</main>